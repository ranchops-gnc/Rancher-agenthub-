{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agenthub.local/schemas/agent-workbench.schema.json",
  "title": "Agent Workbench Configuration Standard",
  "type": "object",
  "required": ["agents", "workflows"],
  "properties": {
    "agents": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/agentDefinition"
      }
    },
    "workflows": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/workflowDefinition"
      }
    }
  },
  "$defs": {
    "agentDefinition": {
      "type": "object",
      "required": ["description", "model", "tools"],
      "properties": {
        "description": {"type": "string", "minLength": 1},
        "model": {"type": "string", "minLength": 1},
        "instructions": {"type": "array", "items": {"type": "string"}},
        "capabilities": {"type": "array", "items": {"type": "string"}},
        "tools": {"type": "array", "items": {"type": "string"}},
        "memory": {
          "type": "object",
          "properties": {
            "workspace": {"type": "boolean"},
            "long_term": {"type": "boolean"}
          },
          "additionalProperties": false
        },
        "permissions": {
          "type": "object",
          "properties": {
            "filesystem": {"type": "string"},
            "network": {"type": "string"},
            "shell": {"type": "string"}
          },
          "additionalProperties": true
        },
        "delegation": {
          "type": "object",
          "properties": {
            "allowed_agents": {"type": "array", "items": {"type": "string"}}
          },
          "additionalProperties": true
        },
        "fallback": {
          "type": "object",
          "properties": {
            "models": {"type": "array", "items": {"type": "string"}},
            "retries": {"type": "integer", "minimum": 0},
            "cooldown": {"type": "string"}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "workflowDefinition": {
      "type": "object",
      "required": ["trigger", "steps"],
      "properties": {
        "trigger": {"type": "string"},
        "steps": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "object",
                "required": ["agent", "action"],
                "properties": {
                  "agent": {"type": "string"},
                  "action": {"type": "string"}
                },
                "additionalProperties": true
              },
              {
                "type": "object",
                "required": ["parallel"],
                "properties": {
                  "parallel": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["agent", "action"],
                      "properties": {
                        "agent": {"type": "string"},
                        "action": {"type": "string"}
                      },
                      "additionalProperties": true
                    }
                  }
                },
                "additionalProperties": true
              },
              {
                "type": "object",
                "required": ["approval"],
                "properties": {
                  "approval": {
                    "type": "object",
                    "required": ["required"],
                    "properties": {
                      "required": {"type": "boolean"},
                      "role": {"type": "string"}
                    },
                    "additionalProperties": true
                  }
                },
                "additionalProperties": true
              }
            ]
          }
        }
      },
      "additionalProperties": true
    }
  }
}
